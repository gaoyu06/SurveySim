generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RunStatus {
  DRAFT
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELING
  CANCELED
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  CANCELED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id           String              @id @default(cuid())
  email        String              @unique
  passwordHash String
  role         UserRole            @default(USER)
  dailyUsageLimit Int?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  llmConfigs   LlmProviderConfig[]
  templates    ParticipantTemplate[]
  surveys      Survey[]
  mockRuns     MockRun[]
  files        StoredFile[]
  dailyUsages  UserDailyUsage[]
}

model LlmProviderConfig {
  id          String   @id @default(cuid())
  userId      String
  name        String
  baseUrl     String
  apiKey      String
  model       String
  temperature Float
  maxTokens   Int
  timeoutMs   Int
  concurrency Int
  retryCount  Int
  isDefault   Boolean  @default(false)
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mockRuns MockRun[]

  @@index([userId])
}

model ParticipantTemplate {
  id                String            @id @default(cuid())
  userId            String
  name              String
  description       String?
  dimensions        Json
  sampleSizePreview Int               @default(200)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules    ParticipantRule[]
  mockRuns MockRun[]

  @@index([userId])
}

model ParticipantRule {
  id         String   @id @default(cuid())
  templateId String
  name       String
  enabled    Boolean  @default(true)
  priority   Int
  scope      Json?
  assignment Json
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template ParticipantTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Survey {
  id                     String          @id @default(cuid())
  userId                 String
  title                  String
  description            String?
  sourceText             String
  respondentInstructions String?
  language               String          @default("auto")
  schema                 Json
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections  SurveySection[]
  questions SurveyQuestion[]
  mockRuns  MockRun[]

  @@index([userId])
}

model SurveySection {
  id           String   @id @default(cuid())
  surveyId     String
  title        String
  description  String?
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  survey    Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questions SurveyQuestion[]

  @@index([surveyId])
}

model SurveyQuestion {
  id                     String   @id @default(cuid())
  surveyId               String
  sectionId              String?
  code                   String?
  type                   String
  title                  String
  description            String?
  required               Boolean  @default(false)
  respondentInstructions String?
  validation             Json?
  displayOrder           Int
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  survey    Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  section   SurveySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  options   SurveyOption[]
  answers   SurveyAnswer[]

  @@index([surveyId])
  @@index([sectionId])
}

model SurveyOption {
  id           String   @id @default(cuid())
  questionId   String
  label        String
  value        String
  displayOrder Int
  allowOther   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model MockRun {
  id                    String    @id @default(cuid())
  userId                String
  name                  String
  participantTemplateId String
  surveyId              String
  llmConfigId           String
  participantCount      Int
  concurrency           Int
  reuseIdentity         Boolean   @default(false)
  reusePersonaPrompt    Boolean   @default(false)
  extraSystemPrompt     String?
  extraRespondentPrompt String?
  status                RunStatus @default(DRAFT)
  progress              Json
  summary               Json?
  startedAt             DateTime?
  completedAt           DateTime?
  canceledAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  participantTemplate ParticipantTemplate   @relation(fields: [participantTemplateId], references: [id], onDelete: Restrict)
  survey              Survey                @relation(fields: [surveyId], references: [id], onDelete: Restrict)
  llmConfig           LlmProviderConfig     @relation(fields: [llmConfigId], references: [id], onDelete: Restrict)
  participantInstances ParticipantInstance[]
  responses           SurveyResponse[]
  logs                RunLog[]
  aggregatedReport    AggregatedReport?

  @@index([userId])
  @@index([surveyId])
  @@index([participantTemplateId])
  @@index([llmConfigId])
}

model ParticipantInstance {
  id           String     @id @default(cuid())
  mockRunId    String
  ordinal      Int
  status       TaskStatus @default(PENDING)
  identity     Json
  errorMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  mockRun       MockRun         @relation(fields: [mockRunId], references: [id], onDelete: Cascade)
  personaProfile PersonaProfile?
  surveyResponse SurveyResponse?
  logs          RunLog[]

  @@index([mockRunId])
}

model PersonaProfile {
  id                    String     @id @default(cuid())
  participantInstanceId String     @unique
  status                TaskStatus @default(PENDING)
  promptText            String?
  rawPayload            Json?
  errorMessage          String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  participantInstance ParticipantInstance @relation(fields: [participantInstanceId], references: [id], onDelete: Cascade)
}

model SurveyResponse {
  id                    String     @id @default(cuid())
  mockRunId             String
  participantInstanceId String     @unique
  status                TaskStatus @default(PENDING)
  rawPayload            Json?
  validationErrors      Json?
  errorMessage          String?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  mockRun            MockRun             @relation(fields: [mockRunId], references: [id], onDelete: Cascade)
  participantInstance ParticipantInstance @relation(fields: [participantInstanceId], references: [id], onDelete: Cascade)
  answers            SurveyAnswer[]

  @@index([mockRunId])
}

model SurveyAnswer {
  id               String   @id @default(cuid())
  surveyResponseId String
  questionId       String
  answer           Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  surveyResponse SurveyResponse @relation(fields: [surveyResponseId], references: [id], onDelete: Cascade)
  question       SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([surveyResponseId])
  @@index([questionId])
}

model RunLog {
  id                    String    @id @default(cuid())
  mockRunId             String
  participantInstanceId String?
  stage                 String
  level                 LogLevel  @default(INFO)
  message               String
  payload               Json?
  createdAt             DateTime  @default(now())

  mockRun             MockRun              @relation(fields: [mockRunId], references: [id], onDelete: Cascade)
  participantInstance ParticipantInstance? @relation(fields: [participantInstanceId], references: [id], onDelete: SetNull)

  @@index([mockRunId])
  @@index([participantInstanceId])
}

model StoredFile {
  id           String   @id @default(cuid())
  userId       String
  kind         String
  originalName String
  mimeType     String
  size         Int
  path         String
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AggregatedReport {
  id        String   @id @default(cuid())
  mockRunId String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mockRun MockRun @relation(fields: [mockRunId], references: [id], onDelete: Cascade)
}

model SystemConfig {
  id                 String   @id @default("system")
  defaultDailyUsageLimit Int  @default(20)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserDailyUsage {
  id         String   @id @default(cuid())
  userId     String
  dateKey    String
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([userId, dateKey])
}
